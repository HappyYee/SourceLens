# Copy this file to .env for local development.
# Never commit .env or real API keys.

# Local SQLite database. The real database lives under data/db/ and is gitignored.
DATABASE_URL="file:./data/db/sourcelens.db"

# Optional: used to enrich YouTube metadata such as duration.
YOUTUBE_API_KEY=

# Optional: used only for lightweight title generation when enabled by code.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Optional: foreign-network refresh can use HTTPS_PROXY / HTTP_PROXY from the shell.
# HTTPS_PROXY=http://127.0.0.1:33210
